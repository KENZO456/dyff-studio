# ─── Notion CMS ───────────────────────────────────────────────────────────────
# Get your API key at https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxx

# Database IDs — copy from the database URL in Notion
# URL format: https://notion.so/workspace/<DATABASE_ID>?v=...
NOTION_BOOKS_DB_ID=xxxx
NOTION_CHAPTERS_DB_ID=xxxx
NOTION_AUDIO_DB_ID=xxxx
NOTION_EPISODES_DB_ID=xxxx
NOTION_ANIMATIONS_DB_ID=xxxx
NOTION_MARKETPLACE_DB_ID=xxxx

# ─── On-demand Revalidation ───────────────────────────────────────────────────
# Random secret for the /api/revalidate webhook.
# Generate with: openssl rand -base64 32
REVALIDATE_SECRET=your-random-secret-here
